{
  "name": "nuxt-zod-i18n",
  "version": "1.12.1",
  "description": "A Nuxt Module for localizing zod error messages.",
  "repository": "xibman/nuxt-zod-i18n",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "workspaces": [
    "playground",
    "docs"
  ],
  "scripts": {
    "check": "npm run lint:fix",
    "dev": "npm run dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "docs:build": "nuxt build docs",
    "docs:dev": "nuxt dev docs",
    "docs:generate": "nuxt generate docs",
    "docs:preview": "nuxt preview docs",
    "fix": "npm run lint:fix",
    "i18n:download": "localazy download && pnpm fix",
    "i18n:upload": "localazy upload",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "prepack": "nuxt-module-build build",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.2",
    "defu": "^6.1.7",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@localazy/cli": "^2.0.8",
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "catalog:",
    "@nuxt/test-utils": "^4.0.2",
    "@nuxtjs/i18n": "catalog:",
    "@types/node": "^25.6.0",
    "changelogen": "^0.6.2",
    "eslint": "catalog:",
    "eslint-plugin-jsonc": "^3.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nuxt": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.1.4",
    "vue-tsc": "catalog:"
  },
  "lint-staged": {
    "*.{js,ts,vue,json,md,yml}": "eslint"
  },
  "packageManager": "pnpm@10.33.0"
}
